{
	"$schema": "CodeGenSchema.json",
	"ApiSelections": {
		"ExcludedControllerNames": [
			"DemoWebApi.Controllers.Home",
			"DemoWebApi.Controllers.FileUpload"
		],

		"DataModels": [
			{
				"AssemblyName": "DemoWebApi.DemoDataCore",
